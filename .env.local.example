# Copy this file to .env.local and fill in your values.
# The site runs on built-in sample data if Supabase vars are blank.
# NEVER commit .env.local — it is gitignored.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# MSG91 — customer OTP + dealer alerts, all over WhatsApp Business API.
# Server-only. Do NOT prefix with NEXT_PUBLIC_.
MSG91_AUTH_KEY=
MSG91_OTP_WHATSAPP_TEMPLATE_ID= # Meta Authentication-category template with a Copy Code
                                # button, approved for OTP. Used by /api/otp/send.
MSG91_WHATSAPP_NAMESPACE=       # Your WhatsApp Business Account namespace (one value,
                                # shared by all templates on this account). Find it via
                                # MSG91 → WhatsApp → Templates → any template → <> "Code
                                # {JSON}" icon — it's the "namespace" field in the sample.
MSG91_OTP_TEMPLATE_ID=          # DEPRECATED — was the SMS OTP-widget (control.msg91.com)
                                # DLT template. No longer read by any route. Customer OTP
                                # now sends over WhatsApp via MSG91_OTP_WHATSAPP_TEMPLATE_ID.
MSG91_WHATSAPP_TEMPLATE_ID=     # Dealer new-lead alert template (Utility, with magic-link buttons)
MSG91_WHATSAPP_NUMBER=          # Your WhatsApp sender number registered in MSG91
MSG91_NUDGE_TEMPLATE_ID=        # Template name for 15-day availability nudge to dealers
                                # Template body: Hi {{1}}, you have {{2}} listing(s) on Prop100
                                # that need an availability update. Tap here: {{3}}
MSG91_LOW_BALANCE_TEMPLATE_ID=     # Owner alert when a lead is pending (wallet empty).
                                    # Needed only once BILLING_ENABLED=true. Masked phone only.
MSG91_CONTACT_DELIVERY_TEMPLATE_ID= # Sent to the CUSTOMER once a pending lead is released
                                    # after the owner tops up. Needed only at billing flip.

# Cron job secret — protects /api/cron/* endpoints from unauthorized calls
# Generate with: openssl rand -hex 32
# Set the same value in Vercel → Settings → Environment Variables
CRON_SECRET=

# App URL — used for magic links in dealer WhatsApp messages
NEXT_PUBLIC_APP_URL=            # e.g. https://prop100.in (no trailing slash)

# Dealer session signing secret (server only — generate with: openssl rand -hex 32)
DEALER_SESSION_SECRET=

# Customer "verified device" cookie — same scheme as DEALER_SESSION_SECRET,
# separate secret so rotating one never invalidates the other.
# Generate with: openssl rand -hex 32
PHONE_VERIFY_SECRET=

# --- Wallet / pay-per-lead billing -----------------------------------------
# BILLING_ENABLED unset/false = every lead is free, shadow-logged at
# LEAD_PRICE_PAISE so month-2 flip can show owners "value delivered free".
# Flip = set BILLING_ENABLED=true and redeploy. No code change.
BILLING_ENABLED=                # "true" to charge wallets; unset = free phase
LEAD_PRICE_PAISE=2500           # ₹25/lead (paise) — changeable anytime
FREE_LEADS_PER_DEALER=5         # evergreen free-leads-on-signup offer

# UPI top-up (manual v1 — owner pays this VPA, taps WhatsApp, admin credits)
NEXT_PUBLIC_UPI_VPA=            # e.g. prop100@upi
NEXT_PUBLIC_CONCIERGE_WHATSAPP= # Bhavya's WhatsApp number for "I've paid" + customer fallback

# Google Maps — Places Autocomplete for the distance calculator on property pages
# Get a key at console.cloud.google.com → APIs & Services → Maps JavaScript API
# Without this key the distance widget is hidden; everything else works normally.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Gemini — AI chatbot (gemini-1.5-flash, free tier available)
# Get a FREE key at aistudio.google.com/apikey (no credit card needed)
# Without this key the chatbot shows a helpful fallback message.
# Server-only. Do NOT prefix with NEXT_PUBLIC_.
GOOGLE_GEMINI_API_KEY=
